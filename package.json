{
  "name": "siberflow",
  "version": "0.1.0",
  "private": true,
  "description": "AI platform with multi-provider support and tool calling",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @siberflow/core && npm run build -w @siberflow/cli && npm run build -w siberflow-chat",
    "build:core": "npm run build -w @siberflow/core",
    "build:desktop": "npm run build -w @siberflow/core && npm run build -w siberflow-desktop",
    "dev:desktop": "npm run dev -w siberflow-desktop",
    "package:desktop": "cd packages/desktop && npm run package",
    "package:win": "cd packages/desktop && npm run package:win",
    "package:mac": "cd packages/desktop && npm run package:mac",
    "package:linux": "cd packages/desktop && npm run package:linux",
    "release:desktop": "cd packages/desktop && npm run release:mac",
    "rebuild:desktop": "cd packages/desktop && npm run rebuild",
    "build:vscode": "npm run build -w siberflow-chat",
    "watch:vscode": "npm run watch -w siberflow-chat",
    "package:vscode": "npm run package -w siberflow-chat",
    "dev:cli": "npm run dev --workspace=@siberflow/cli",
    "cli": "npm run start --workspace=@siberflow/cli",
    "clean": "rm -rf packages/*/dist packages/*/out"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "tar": "^7.5.16",
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "app-builder-bin": "^5.0.0-alpha.10",
    "electron-builder": "^25.1.8"
  }
}
