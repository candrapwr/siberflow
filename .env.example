# Default provider: deepseek | gemini | openai | openai-responses | grok | qwen
SIBERFLOW_PROVIDER=deepseek

# Default model (provider-specific). Leave empty to use provider's default.
#   deepseek          -> deepseek-chat
#   gemini            -> gemini-2.5-flash
#   openai            -> gpt-5.4-nano (uses /v1/chat/completions)
#   openai-responses  -> gpt-5.1-codex-mini (uses /v1/responses; required for
#                        codex / some o-series / some gpt-5 models)
#   grok              -> grok-build-0.1 (xAI)
#   qwen              -> qwen3.7-plus (Alibaba DashScope / MaaS)
SIBERFLOW_MODEL=deepseek-chat

# Base URL override (optional). Useful for custom MaaS endpoints (Qwen
# private workspace) or self-hosted compatible endpoints.
#   qwen + custom MaaS: https://llm-<id>.<region>.maas.aliyuncs.com/compatible-mode/v1
# SIBERFLOW_BASE_URL=

# DeepSeek API key — get from https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Gemini API key — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI API key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# xAI Grok API key — get from https://console.x.ai/
XAI_API_KEY=

# Alibaba Qwen (DashScope) API key — get from https://bailian.console.aliyun.com/
# (or your MaaS workspace if using a dedicated deployment)
DASHSCOPE_API_KEY=

# Working directory for tools (file_* and exec). Absolute path or ~/path.
# Default: INIT_CWD (npm-invoked location), then process.cwd().
# SIBERFLOW_PROJECT_DIR=/Volumes/Workspace/my-project

# Context optimization (Layer 1).
# When enabled, tool calls & results from PREVIOUS user turns are dropped
# before sending to the LLM, keeping only the assistant's final text per
# turn. Current turn's tool activity is always kept full. Session history
# on disk is NOT modified — only the in-flight request view.
# SIBERFLOW_CONTEXT_OPTIMIZE=false

# Task checklist (default off). When enabled, registers a task_update tool
# so the model can maintain a checklist for complex multi-step tasks. The
# list is re-injected into context each turn (survives optimization) and
# rendered in the CLI. Persisted per session.
# SIBERFLOW_TASKS=false

# Auto-continue responses cut off by the model's output token limit
# (finishReason="length"). Default ON. Set to false to disable (response
# will just stop mid-text). Capped at a few continuations per turn.
# SIBERFLOW_AUTO_CONTINUE=true

# Verbose tracing to stderr: HTTP status, raw finish_reason, usage, errors,
# stream lifecycle. Useful for debugging cut-off / stalled responses.
# Redirect to a file: npm run dev:cli 2>debug.log
# SIBERFLOW_DEBUG=true

# Max tool-calling iterations per turn (default 50). Raise for large
# multi-step tasks (e.g. scaffolding a whole module). When hit, the CLI
# prompts you to type "continue".
# SIBERFLOW_MAX_ITERATIONS=50

# Hide tool call details in the CLI (header, args, result). When true,
# tool activity shows only as a spinner labelled with the tool name —
# cleaner output. Default false (show full tool detail).
# SIBERFLOW_HIDE_TOOLS=false
