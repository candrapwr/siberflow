## Default provider: deepseek | gemini | openai | openai-responses | grok | qwen | zai | claude
SIBERFLOW_PROVIDER=deepseek

## Default model (provider-specific). Leave empty to use provider's default.
##   deepseek          -> deepseek-v4-flash
##   gemini            -> gemini-2.5-flash
##   openai            -> gpt-5.4-nano (uses /v1/chat/completions)
##   openai-responses  -> gpt-5.1-codex-mini (uses /v1/responses; required for
##                        codex / some o-series / some gpt-5 models)
##   grok              -> grok-build-0.1 (xAI)
##   qwen              -> qwen3.7-plus (Alibaba DashScope / MaaS)
##   zai               -> glm-5.2 (Z.AI / GLM via OpenAI-compatible chat completions)
##   claude            -> claude-sonnet-4-5 (Anthropic, OpenAI-compatible chat completions)
SIBERFLOW_MODEL=deepseek-v4-flash

## Base URL override (optional). Useful for custom MaaS endpoints (Qwen
## private workspace), Z.AI coding endpoint, or self-hosted compatible endpoints.
##   qwen + custom MaaS: https://llm-<id>.<region>.maas.aliyuncs.com/compatible-mode/v1
##   zai + coding plan: https://api.z.ai/api/coding/paas/v4
# SIBERFLOW_BASE_URL=

## DeepSeek API key — get from https://platform.deepseek.com/
DEEPSEEK_API_KEY=

## Gemini API key — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

## OpenAI API key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

## xAI Grok API key — get from https://console.x.ai/
XAI_API_KEY=

## Alibaba Qwen (DashScope) API key — get from https://bailian.console.aliyun.com/
## (or your MaaS workspace if using a dedicated deployment)
DASHSCOPE_API_KEY=

## Z.AI API key — get from https://platform.z.ai/ or the Z.AI console/docs flow
ZAI_API_KEY=

## Anthropic API key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

## Working directory for tools (file_* and exec). Absolute path or ~/path.
## Default: INIT_CWD (npm-invoked location), then process.cwd().
# SIBERFLOW_PROJECT_DIR=/Volumes/Workspace/my-project

## Context optimization (Layer 1). Default ON.
## When enabled, tool calls & results from PREVIOUS user turns are dropped
## before sending to the LLM, keeping only the assistant's final text per
## turn. Current turn's tool activity is always kept full. Session history
## on disk is NOT modified — only the in-flight request view.
# SIBERFLOW_CONTEXT_OPTIMIZE=true

## Optimization strategy (only honored when SIBERFLOW_CONTEXT_OPTIMIZE=true).
##   recent  — (default) like summary, but keep the MOST RECENT completed
##             turn's tool activity INTACT (only turns older than that get
##             compressed). Useful when the immediately preceding tool context
##             matters and shouldn't be reduced to a signature yet. No
##             compression happens until the 3rd turn (1st & 2nd turn have
##             nothing eligible).
##   summary — leave a [SUMMARY] breadcrumb on EACH past user turn (including
##             the most recent completed one) with a compact tool SIGNATURE
##             per call (name + short identifier args like
##             path/command/query/line range). Heavy payloads (file contents,
##             edit patches, task lists) and tool results are still removed.
##   drop    — remove tool history entirely (most compact; no breadcrumb).
# SIBERFLOW_CONTEXT_OPTIMIZE_MODE=recent

## Task checklist (default off). When enabled, registers a task_update tool
## so the model can maintain a checklist for complex multi-step tasks. The
## list is re-injected into context each turn (survives optimization) and
## rendered in the CLI. Persisted per session.
# SIBERFLOW_TASKS=false

## Auto-continue responses cut off by the model's output token limit
## (finishReason="length"). Default ON. Set to false to disable (response
## will just stop mid-text). Capped at a few continuations per turn.
# SIBERFLOW_AUTO_CONTINUE=true

## Verbose tracing to stderr: HTTP status, raw finish_reason, usage, errors,
## stream lifecycle. Useful for debugging cut-off / stalled responses.
## Redirect to a file: npm run dev:cli 2>debug.log
# SIBERFLOW_DEBUG=true

## Max tool-calling iterations per turn (default 50). Raise for large
## multi-step tasks (e.g. scaffolding a whole module). When hit, the CLI
## prompts you to type "continue".
# SIBERFLOW_MAX_ITERATIONS=50

## Delay (ms) before each request to the LLM, to avoid provider rate-limiting /
## blocking during fast tool-call loops (default 1500 = 1.5s). Set to 0 to
## disable (useful for paid tiers or self-hosted endpoints with no rate limit).
## Applied once per LLM request: initial response, auto-continues, and every
## tool-call iteration. Negative/garbage values fall back to the default.
# SIBERFLOW_REQUEST_DELAY_MS=1500

## Hide tool call details in the CLI (header, args, result). When true,
## tool activity shows only as a spinner labelled with the tool name —
## cleaner output. Default false (show full tool detail).
# SIBERFLOW_HIDE_TOOLS=false

## Max consecutive run_browser calls in a single turn before the agent stops
## browsing and forces a final text answer (default 10). Set to 0 to disable
## the cap entirely (allow unlimited consecutive browsing).
# SIBERFLOW_MAX_CONSECUTIVE_RUN_BROWSER=10

## Which tools are registered for the AI (comma-separated list of tool names).
## Disabled tools aren't sent in the prompt, saving tokens and shrinking the
## attack surface. Default: file operations only:
##   SIBERFLOW_TOOLS=read_file,write_file,edit_file,copy_file,list_dir
## Available tools:
##   file:   read_file, write_file, edit_file, copy_file, list_dir
##   shell:  exec
##   db:     db_query      (MySQL / PostgreSQL / SQLite)
##   ssh:    ssh_exec, sftp
##   excel:  excel_script
##   doc:    docx_script  (create/read Word .docx via docx + mammoth libraries)
##   pdf:    pdf_script   (create/read .pdf via pdf-lib + pdfjs-dist)
##   browser: run_browser  (headless Chrome/Edge via Puppeteer; uses system browser, no download)
##   image:  analyze_image (OpenAI-compatible multimodal model for image OCR/analysis)
##   bot:    bot_script    (bot host actions such as sending messages/photos/documents)
##   web:    web_search    (web search + page content via Exa; needs SIBERFLOW_EXA_API_KEY)
##   speech: text_to_speech, speech_to_text (edge-tts + SpeechRecognition; needs python3 + ffmpeg)
## task_update is never controlled here — it's gated by SIBERFLOW_TASKS.
## Example: file ops + shell + db:
##   SIBERFLOW_TOOLS=read_file,write_file,edit_file,copy_file,list_dir,exec,db_query
## Empty string = no tools at all (only task_update if SIBERFLOW_TASKS=true):
##   SIBERFLOW_TOOLS=
# SIBERFLOW_TOOLS=read_file,write_file,edit_file,copy_file,list_dir

## Multimodal image analysis provider for analyze_image.
## Must be OpenAI-compatible /chat/completions with image_url content support.
# SIBERFLOW_MULTIMODAL_BASE_URL=https://api.openai.com/v1/
# SIBERFLOW_MULTIMODAL_MODEL=gpt-4o-mini
# SIBERFLOW_MULTIMODAL_API_KEY=

## Web search provider for web_search (Exa). Required to enable web_search.
# SIBERFLOW_EXA_API_KEY=
## Optional base URL override (defaults to https://api.exa.ai):
# SIBERFLOW_EXA_BASE_URL=https://api.exa.ai

## Telegram bot integration. Uses Bot API long polling.
## Private chats stream through sendRichMessageDraft and finalize with
## sendRichMessage. Groups/supergroups get a final sendRichMessage only because
## Telegram drafts are private-chat scoped.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_API_BASE_URL=https://api.telegram.org
# SIBERFLOW_TELEGRAM_WORKDIR_ROOT=~/.siberflow/telegram-workdirs
## Telegram-specific provider/model override. API keys are still read from the
## provider's global key env (DEEPSEEK_API_KEY, OPENAI_API_KEY, etc.).
# SIBERFLOW_TELEGRAM_PROVIDER=deepseek
# SIBERFLOW_TELEGRAM_MODEL=deepseek-v4-flash
## Optional Telegram-specific model API override. This is the model provider
## base URL, not the Telegram Bot API URL above.
# SIBERFLOW_TELEGRAM_BASE_URL=
# SIBERFLOW_TELEGRAM_API_KEY=
## For SIBERFLOW_TELEGRAM_PROVIDER=custom:
# SIBERFLOW_TELEGRAM_CUSTOM_PROVIDER_NAME=my-provider
# SIBERFLOW_TELEGRAM_CUSTOM_DEFAULT_MODEL=model-name
## Tools available to the Telegram bot only. Defaults to run_browser.
## Use a comma-separated list. Empty string = no tools.
## bot_script lets the agent run bot actions in the active Telegram chat/thread.
## Add file tools here too when the bot should manipulate files in its workdir.
# SIBERFLOW_TELEGRAM_TOOLS=run_browser,analyze_image,bot_script,web_search

## Force ONE session per chat (ignore forum topics / threads). Default: off —
## real forum topics get their own session. Set "true" if your group is NOT a
## forum but you still see sessions splitting by thread id.
# SIBERFLOW_TELEGRAM_ONE_SESSION_PER_CHAT=false

## Telegram bot admins who get shell (exec) access in PRIVATE chats only.
## Comma-separated list of Telegram user IDs (numeric, preferred) or usernames
## (with or without @, case-insensitive). Exec is NEVER available in groups.
## Example: SIBERFLOW_TELEGRAM_ADMINS=123456789,@candrapwr
# SIBERFLOW_TELEGRAM_ADMINS=
