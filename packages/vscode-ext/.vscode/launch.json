{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Siberflow Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/dist/**/*.cjs"],
      "preLaunchTask": "${defaultBuildTask}"
    }
  ]
}
