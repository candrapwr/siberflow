{
  "name": "siberflow-chat",
  "version": "0.5.30",
  "displayName": "Siberflow",
  "description": "AI chat sidebar with multi-provider, tool calling, sandboxed file ops, and task checklists.",
  "publisher": "DatasiberLab",
  "license": "MIT",
  "icon": "resources/siberflow.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/candrapwr/siberflow"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "chat",
    "agent",
    "deepseek",
    "gemini",
    "openai",
    "codex",
    "assistant",
    "glm",
    "zai"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.cjs",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "siberflow",
          "title": "Siberflow",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "siberflow": [
        {
          "id": "siberflow.chatView",
          "name": "Chat",
          "type": "webview",
          "icon": "resources/icon.svg",
          "contextualTitle": "Siberflow"
        }
      ]
    },
    "commands": [
      {
        "command": "siberflow.openChat",
        "title": "Siberflow: Open Chat"
      },
      {
        "command": "siberflow.newSession",
        "title": "Siberflow: New Session"
      },
      {
        "command": "siberflow.loadSession",
        "title": "Siberflow: Load Session"
      },
      {
        "command": "siberflow.deleteSession",
        "title": "Siberflow: Delete Session"
      },
      {
        "command": "siberflow.clearAllSessions",
        "title": "Siberflow: Clear All Sessions"
      },
      {
        "command": "siberflow.showUsage",
        "title": "Siberflow: Show Usage"
      },
      {
        "command": "siberflow.showTools",
        "title": "Siberflow: List Tools"
      },
      {
        "command": "siberflow.openSettings",
        "title": "Siberflow: Open Settings"
      }
    ],
    "configuration": {
      "title": "Siberflow",
      "properties": {
        "siberflow.provider": {
          "type": "string",
          "enum": [
            "deepseek",
            "gemini",
            "openai",
            "openai-responses",
            "grok",
            "qwen",
            "zai",
            "claude",
            "custom"
          ],
          "default": "deepseek",
          "description": "Active LLM provider"
        },
        "siberflow.customProvider": {
          "type": "object",
          "default": {
            "name": "custom",
            "baseUrl": "",
            "defaultModel": ""
          },
          "properties": {
            "name": {
              "type": "string",
              "default": "custom",
              "description": "Display/internal name for the custom OpenAI-compatible provider."
            },
            "baseUrl": {
              "type": "string",
              "default": "",
              "description": "OpenAI-compatible API root URL, for example https://api.example.com/v1. Siberflow appends /chat/completions."
            },
            "defaultModel": {
              "type": "string",
              "default": "",
              "description": "Default model to use when siberflow.model is empty."
            }
          },
          "description": "Configuration used when siberflow.provider is custom."
        },
        "siberflow.multimodalProvider": {
          "type": "object",
          "default": {
            "baseUrl": "https://api.openai.com/v1",
            "model": ""
          },
          "properties": {
            "baseUrl": {
              "type": "string",
              "default": "https://api.openai.com/v1",
              "description": "OpenAI-compatible API root URL for analyze_image. Siberflow appends /chat/completions."
            },
            "model": {
              "type": "string",
              "default": "",
              "description": "Multimodal model used by analyze_image."
            }
          },
          "description": "Configuration used by analyze_image."
        },
        "siberflow.model": {
          "type": "string",
          "default": "",
          "description": "Model override (leave empty for provider default)"
        },
        "siberflow.contextOptimize": {
          "type": "boolean",
          "default": true
        },
        "siberflow.contextOptimizeMode": {
          "type": "string",
          "enum": [
            "drop",
            "summary",
            "recent",
            "compact"
          ],
          "default": "compact",
          "description": "Context optimization strategy. compact = generate an LLM narrative summary of older turns when context fills up (default; richest retention, costs 1 extra API call); recent = signature breadcrumb on past turns but keep the most recent completed turn intact; summary = signature breadcrumb on ALL past turns; drop = remove tool history entirely. Only applies when contextOptimize is true."
        },
        "siberflow.contextWindow": {
          "type": "number",
          "default": 200000,
          "description": "Compact-mode: max prompt tokens (context window budget) of the active provider, used by the threshold trigger. Default 200000 (GLM-5.x / Claude-class). Set higher for 1M providers (DeepSeek-V4, Qwen-Plus, MiniMax) so they compact later. Only applies when contextOptimizeMode is compact."
        },
        "siberflow.compactThreshold": {
          "type": "number",
          "default": 0.8,
          "description": "Compact-mode: ratio (0..1) of (last prompt tokens / contextWindow) at which summarization fires. Lower = compact sooner & more often; higher = compact later. Only applies when contextOptimizeMode is compact."
        },
        "siberflow.compactKeepRecent": {
          "type": "number",
          "default": 2,
          "description": "Compact-mode: how many of the most recent COMPLETED turns stay verbatim (not folded into the summary) when compaction fires. 0 folds everything older than the current turn. Only applies when contextOptimizeMode is compact."
        },
        "siberflow.autoContinue": {
          "type": "boolean",
          "default": true
        },
        "siberflow.hideTools": {
          "type": "boolean",
          "default": true
        },
        "siberflow.maxIterations": {
          "type": "number",
          "default": 50
        },
        "siberflow.requestDelayMs": {
          "type": "number",
          "default": 1500,
          "description": "Delay (ms) before each request to the LLM to avoid rate-limiting. 0 = off."
        },
        "siberflow.enabledTools": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "read_file",
            "write_file",
            "edit_file",
            "copy_file",
            "list_dir",
            "delete_file",
            "grep"
          ],
          "description": "Which tools are registered for the AI. Disabled tools aren't sent in the prompt. Default: file operations only."
        },
        "siberflow.debug": {
          "type": "boolean",
          "default": false
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "prepackage": "npm run build && node scripts/stage-puppeteer.mjs stage",
    "package": "vsce package --no-dependencies --allow-package-all-secrets",
    "postpackage": "node scripts/stage-puppeteer.mjs clean",
    "prepublish": "npm run build && node scripts/stage-puppeteer.mjs stage",
    "publish": "vsce publish --no-dependencies --allow-package-all-secrets",
    "postpublish": "node scripts/stage-puppeteer.mjs clean",
    "clean": "rm -rf dist *.vsix"
  },
  "dependencies": {
    "@siberflow/core": "0.1.0",
    "marked": "^14.1.0",
    "puppeteer-core": "^25.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.3"
  }
}
